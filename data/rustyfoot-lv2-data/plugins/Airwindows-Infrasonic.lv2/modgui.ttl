@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/infrasonic>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-infrasonic.html> ;
        modgui:stylesheet <modgui/stylesheet-infrasonic.css> ;
        modgui:screenshot <modgui/screenshot-infrasonic.png> ;
        modgui:thumbnail <modgui/thumbnail-infrasonic.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Infrasonic" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "zinc" ;
    ] .
