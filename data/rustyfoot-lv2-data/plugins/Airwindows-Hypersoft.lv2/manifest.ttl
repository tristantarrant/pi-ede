@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/hypersoft>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-hypersoft.html> ;
        modgui:stylesheet <modgui/stylesheet-hypersoft.css> ;
        modgui:screenshot <modgui/screenshot-hypersoft.png> ;
        modgui:thumbnail <modgui/thumbnail-hypersoft.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Hypersoft" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "input" ;
            lv2:name "Input" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "depth" ;
            lv2:name "Depth" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "bright" ;
            lv2:name "Bright" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] ;
    ] .
