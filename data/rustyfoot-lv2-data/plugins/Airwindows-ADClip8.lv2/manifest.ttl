@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/adclip8>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-adclip8.html> ;
        modgui:stylesheet <modgui/stylesheet-adclip8.css> ;
        modgui:screenshot <modgui/screenshot-adclip8.png> ;
        modgui:thumbnail <modgui/thumbnail-adclip8.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ADClip8" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "black" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "boost" ;
            lv2:name "Boost" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "ceiling" ;
            lv2:name "Ceiling" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "mode" ;
            lv2:name "Mode" ;
        ] ;
    ] .
