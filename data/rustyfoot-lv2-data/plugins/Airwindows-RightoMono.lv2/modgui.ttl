@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/rightomono>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-rightomono.html> ;
        modgui:stylesheet <modgui/stylesheet-rightomono.css> ;
        modgui:screenshot <modgui/screenshot-rightomono.png> ;
        modgui:thumbnail <modgui/thumbnail-rightomono.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "RightoMono" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "orange" ;
    ] .
