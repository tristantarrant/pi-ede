@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/cabs>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-cabs.html> ;
        modgui:stylesheet <modgui/stylesheet-cabs.css> ;
        modgui:screenshot <modgui/screenshot-cabs.png> ;
        modgui:thumbnail <modgui/thumbnail-cabs.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Cabs" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "lava" ;
        modgui:knob "copper" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "cabType" ;
            lv2:name "CabType" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "intense" ;
            lv2:name "Intense" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "rmLoud" ;
            lv2:name "Rm Loud" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "cabSize" ;
            lv2:name "Cab Size" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "offAxis" ;
            lv2:name "OffAxsis" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] ;
    ] .
