@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/subsonly>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-subsonly.html> ;
        modgui:stylesheet <modgui/stylesheet-subsonly.css> ;
        modgui:screenshot <modgui/screenshot-subsonly.png> ;
        modgui:thumbnail <modgui/thumbnail-subsonly.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "SubsOnly" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "wood0" ;
    ] .
