@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/ultrasonicmed>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-ultrasonicmed.html> ;
        modgui:stylesheet <modgui/stylesheet-ultrasonicmed.css> ;
        modgui:screenshot <modgui/screenshot-ultrasonicmed.png> ;
        modgui:thumbnail <modgui/thumbnail-ultrasonicmed.png> ;
        modgui:brand "Hannes" ;
        modgui:label "UltrasonicMed" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "gold" ;
    ] .
