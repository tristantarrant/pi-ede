@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/purestconsolebuss>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-purestconsolebuss.html> ;
        modgui:stylesheet <modgui/stylesheet-purestconsolebuss.css> ;
        modgui:screenshot <modgui/screenshot-purestconsolebuss.png> ;
        modgui:thumbnail <modgui/thumbnail-purestconsolebuss.png> ;
        modgui:brand "Hannes" ;
        modgui:label "PurestConsoleBuss" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "black" ;
    ] .
