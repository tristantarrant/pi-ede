@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/channel9>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-channel9.html> ;
        modgui:stylesheet <modgui/stylesheet-channel9.css> ;
        modgui:screenshot <modgui/screenshot-channel9.png> ;
        modgui:thumbnail <modgui/thumbnail-channel9.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Channel9" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "yellow" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "consoletype" ;
            lv2:name "Console Type" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] ;
    ] .
