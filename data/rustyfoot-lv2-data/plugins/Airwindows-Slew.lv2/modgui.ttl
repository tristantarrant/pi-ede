@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/slew>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-slew.html> ;
        modgui:stylesheet <modgui/stylesheet-slew.css> ;
        modgui:screenshot <modgui/screenshot-slew.png> ;
        modgui:thumbnail <modgui/thumbnail-slew.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Slew" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "warning" ;
        modgui:knob "aluminium" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "clamping" ;
            lv2:name "Clamping" ;
        ] ;
    ] .
