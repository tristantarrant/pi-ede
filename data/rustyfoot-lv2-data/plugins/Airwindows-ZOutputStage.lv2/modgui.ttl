@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/zoutputstage>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-zoutputstage.html> ;
        modgui:stylesheet <modgui/stylesheet-zoutputstage.css> ;
        modgui:screenshot <modgui/screenshot-zoutputstage.png> ;
        modgui:thumbnail <modgui/thumbnail-zoutputstage.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ZOutputStage" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "cyan" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "input" ;
            lv2:name "Input" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] ;
    ] .
