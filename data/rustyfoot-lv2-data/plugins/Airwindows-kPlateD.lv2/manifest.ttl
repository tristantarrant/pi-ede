@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/kplated>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-kplated.html> ;
        modgui:stylesheet <modgui/stylesheet-kplated.css> ;
        modgui:screenshot <modgui/screenshot-kplated.png> ;
        modgui:thumbnail <modgui/thumbnail-kplated.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "kPlateD" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "petrol" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "inputPad" ;
            lv2:name "InputPad" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "damping" ;
            lv2:name "Damping" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "lowCut" ;
            lv2:name "Low Cut" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "predelay" ;
            lv2:name "Predelay" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "wetness" ;
            lv2:name "Wetness" ;
        ] ;
    ] .
