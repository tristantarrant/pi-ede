@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/matrixverb>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-matrixverb.html> ;
        modgui:stylesheet <modgui/stylesheet-matrixverb.css> ;
        modgui:screenshot <modgui/screenshot-matrixverb.png> ;
        modgui:thumbnail <modgui/thumbnail-matrixverb.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "MatrixVerb" ;
        modgui:model "boxy" ;
        modgui:panel "7-knobs" ;
        modgui:color "wood2" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "filter" ;
            lv2:name "Filter" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "damping" ;
            lv2:name "Damping" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "speed" ;
            lv2:name "Speed" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "vibrato" ;
            lv2:name "Vibrato" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "rmsize" ;
            lv2:name "RmSize" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "flavor" ;
            lv2:name "Flavor" ;
        ] , [
            lv2:index 10 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
