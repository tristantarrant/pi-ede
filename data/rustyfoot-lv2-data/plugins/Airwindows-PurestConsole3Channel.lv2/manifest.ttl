@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/purestconsole3channel>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-purestconsole3channel.html> ;
        modgui:stylesheet <modgui/stylesheet-purestconsole3channel.css> ;
        modgui:screenshot <modgui/screenshot-purestconsole3channel.png> ;
        modgui:thumbnail <modgui/thumbnail-purestconsole3channel.png> ;
        modgui:brand "Hannes" ;
        modgui:label "PurestConsole3Channel" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "lava" ;
    ] .
