@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/consolelabuss>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-consolelabuss.html> ;
        modgui:stylesheet <modgui/stylesheet-consolelabuss.css> ;
        modgui:screenshot <modgui/screenshot-consolelabuss.png> ;
        modgui:thumbnail <modgui/thumbnail-consolelabuss.png> ;
        modgui:brand "Hannes" ;
        modgui:label "ConsoleLABuss" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "tribal1" ;
        modgui:knob "petrol" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "master" ;
            lv2:name "Master" ;
        ] ;
    ] .
