@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/purestdrive>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-purestdrive.html> ;
        modgui:stylesheet <modgui/stylesheet-purestdrive.css> ;
        modgui:screenshot <modgui/screenshot-purestdrive.png> ;
        modgui:thumbnail <modgui/thumbnail-purestdrive.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "PurestDrive" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "pink" ;
        modgui:knob "blue" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] ;
    ] .
