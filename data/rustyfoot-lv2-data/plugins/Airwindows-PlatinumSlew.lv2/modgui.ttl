@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/platinumslew>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-platinumslew.html> ;
        modgui:stylesheet <modgui/stylesheet-platinumslew.css> ;
        modgui:screenshot <modgui/screenshot-platinumslew.png> ;
        modgui:thumbnail <modgui/thumbnail-platinumslew.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "PlatinumSlew" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "warning" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "slew" ;
            lv2:name "Slew" ;
        ] ;
    ] .
