@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/console6buss>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-console6buss.html> ;
        modgui:stylesheet <modgui/stylesheet-console6buss.css> ;
        modgui:screenshot <modgui/screenshot-console6buss.png> ;
        modgui:thumbnail <modgui/thumbnail-console6buss.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Console6Buss" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "lava" ;
        modgui:knob "copper" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "input" ;
            lv2:name "Input" ;
        ] ;
    ] .
