@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/rawtimbers>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-rawtimbers.html> ;
        modgui:stylesheet <modgui/stylesheet-rawtimbers.css> ;
        modgui:screenshot <modgui/screenshot-rawtimbers.png> ;
        modgui:thumbnail <modgui/thumbnail-rawtimbers.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "RawTimbers" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "racing" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "quantizer" ;
            lv2:name "Quantizer" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "deRez" ;
            lv2:name "DeRez" ;
        ] ;
    ] .
