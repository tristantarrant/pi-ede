@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/brightambience>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-brightambience.html> ;
        modgui:stylesheet <modgui/stylesheet-brightambience.css> ;
        modgui:screenshot <modgui/screenshot-brightambience.png> ;
        modgui:thumbnail <modgui/thumbnail-brightambience.png> ;
        modgui:brand "Hannes" ;
        modgui:label "BrightAmbience" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "dots" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "sustain" ;
            lv2:name "Sustain" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "decay" ;
            lv2:name "Decay" ;
        ] ;
    ] .
