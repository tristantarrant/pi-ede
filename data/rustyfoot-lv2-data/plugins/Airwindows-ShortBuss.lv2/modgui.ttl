@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/shortbuss>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-shortbuss.html> ;
        modgui:stylesheet <modgui/stylesheet-shortbuss.css> ;
        modgui:screenshot <modgui/screenshot-shortbuss.png> ;
        modgui:thumbnail <modgui/thumbnail-shortbuss.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ShortBuss" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "gray" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "shortBuss" ;
            lv2:name "ShortBuss" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
