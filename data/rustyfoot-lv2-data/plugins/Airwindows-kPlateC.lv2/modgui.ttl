@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/kplatec>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-kplatec.html> ;
        modgui:stylesheet <modgui/stylesheet-kplatec.css> ;
        modgui:screenshot <modgui/screenshot-kplatec.png> ;
        modgui:thumbnail <modgui/thumbnail-kplatec.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "kPlateC" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "red" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "inputPad" ;
            lv2:name "InputPad" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "damping" ;
            lv2:name "Damping" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "lowCut" ;
            lv2:name "Low Cut" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "predelay" ;
            lv2:name "Predelay" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "wetness" ;
            lv2:name "Wetness" ;
        ] ;
    ] .
