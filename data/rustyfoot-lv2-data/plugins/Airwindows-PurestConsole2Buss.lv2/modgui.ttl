@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/purestconsole2buss>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-purestconsole2buss.html> ;
        modgui:stylesheet <modgui/stylesheet-purestconsole2buss.css> ;
        modgui:screenshot <modgui/screenshot-purestconsole2buss.png> ;
        modgui:thumbnail <modgui/thumbnail-purestconsole2buss.png> ;
        modgui:brand "Hannes" ;
        modgui:label "PurestConsole2Buss" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "white" ;
    ] .
