@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/consolelachannel>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-consolelachannel.html> ;
        modgui:stylesheet <modgui/stylesheet-consolelachannel.css> ;
        modgui:screenshot <modgui/screenshot-consolelachannel.png> ;
        modgui:thumbnail <modgui/thumbnail-consolelachannel.png> ;
        modgui:brand "Hannes" ;
        modgui:label "ConsoleLAChannel" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "wood0" ;
        modgui:knob "blue" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "treble" ;
            lv2:name "Treble" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "mid" ;
            lv2:name "Mid" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "bass" ;
            lv2:name "Bass" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "pan" ;
            lv2:name "Pan" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "fader" ;
            lv2:name "Fader" ;
        ] ;
    ] .
