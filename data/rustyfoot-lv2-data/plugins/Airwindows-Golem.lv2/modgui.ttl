@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/golem>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-golem.html> ;
        modgui:stylesheet <modgui/stylesheet-golem.css> ;
        modgui:screenshot <modgui/screenshot-golem.png> ;
        modgui:thumbnail <modgui/thumbnail-golem.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Golem" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "gold" ;
        modgui:knob "purple" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "balance" ;
            lv2:name "Balance" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "offset" ;
            lv2:name "Offset" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "phase" ;
            lv2:name "Phase" ;
        ] ;
    ] .
