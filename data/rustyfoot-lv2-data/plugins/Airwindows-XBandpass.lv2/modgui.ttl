@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/xbandpass>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-xbandpass.html> ;
        modgui:stylesheet <modgui/stylesheet-xbandpass.css> ;
        modgui:screenshot <modgui/screenshot-xbandpass.png> ;
        modgui:thumbnail <modgui/thumbnail-xbandpass.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "XBandpass" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "lava" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "gain" ;
            lv2:name "Gain" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "freq" ;
            lv2:name "Freq" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "nuke" ;
            lv2:name "Nuke" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
