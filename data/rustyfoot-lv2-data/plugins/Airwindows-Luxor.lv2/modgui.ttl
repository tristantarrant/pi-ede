@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/luxor>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-luxor.html> ;
        modgui:stylesheet <modgui/stylesheet-luxor.css> ;
        modgui:screenshot <modgui/screenshot-luxor.png> ;
        modgui:thumbnail <modgui/thumbnail-luxor.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Luxor" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "gray" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "hardness" ;
            lv2:name "Hardness" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "personality" ;
            lv2:name "Personality" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "outputLevel" ;
            lv2:name "Output Level" ;
        ] ;
    ] .
