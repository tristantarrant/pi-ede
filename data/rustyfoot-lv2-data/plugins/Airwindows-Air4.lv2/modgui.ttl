@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/air4>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-air4.html> ;
        modgui:stylesheet <modgui/stylesheet-air4.css> ;
        modgui:screenshot <modgui/screenshot-air4.png> ;
        modgui:thumbnail <modgui/thumbnail-air4.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Air4" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "petrol" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "air" ;
            lv2:name "Air" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "gnd" ;
            lv2:name "Gnd" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "darkF" ;
            lv2:name "DarkF" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "ratio" ;
            lv2:name "Ratio" ;
        ] ;
    ] .
