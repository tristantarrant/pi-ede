@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/kguitarhall2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-kguitarhall2.html> ;
        modgui:stylesheet <modgui/stylesheet-kguitarhall2.css> ;
        modgui:screenshot <modgui/screenshot-kguitarhall2.png> ;
        modgui:thumbnail <modgui/thumbnail-kguitarhall2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "kGuitarHall2" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "dots" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "regen" ;
            lv2:name "Regen" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "derez" ;
            lv2:name "Derez" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "filter" ;
            lv2:name "Filter" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "earlyRF" ;
            lv2:name "EarlyRF" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "positin" ;
            lv2:name "Positin" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
