@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/facet>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-facet.html> ;
        modgui:stylesheet <modgui/stylesheet-facet.css> ;
        modgui:screenshot <modgui/screenshot-facet.png> ;
        modgui:thumbnail <modgui/thumbnail-facet.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Facet" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "warning" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "facet" ;
            lv2:name "Facet" ;
        ] ;
    ] .
