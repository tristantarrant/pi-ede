@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/ironoxideclassic2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-ironoxideclassic2.html> ;
        modgui:stylesheet <modgui/stylesheet-ironoxideclassic2.css> ;
        modgui:screenshot <modgui/screenshot-ironoxideclassic2.png> ;
        modgui:thumbnail <modgui/thumbnail-ironoxideclassic2.png> ;
        modgui:brand "Hannes" ;
        modgui:label "IronOxideClassic2" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "purple" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "inputTrim" ;
            lv2:name "Input Trin" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "tapeSpeed" ;
            lv2:name "Tape Speed" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "outputTrim" ;
            lv2:name "Output Trim" ;
        ] ;
    ] .
