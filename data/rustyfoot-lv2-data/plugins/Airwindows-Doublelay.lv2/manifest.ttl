@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/doublelay>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-doublelay.html> ;
        modgui:stylesheet <modgui/stylesheet-doublelay.css> ;
        modgui:screenshot <modgui/screenshot-doublelay.png> ;
        modgui:thumbnail <modgui/thumbnail-doublelay.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Doublelay" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "detune" ;
            lv2:name "Detune" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "delayL" ;
            lv2:name "Delay L" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "delayR" ;
            lv2:name "Delay R" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "feedbk" ;
            lv2:name "Feedbk" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
