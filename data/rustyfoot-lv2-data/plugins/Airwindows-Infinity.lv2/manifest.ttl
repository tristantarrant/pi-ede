@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/infinity>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-infinity.html> ;
        modgui:stylesheet <modgui/stylesheet-infinity.css> ;
        modgui:screenshot <modgui/screenshot-infinity.png> ;
        modgui:thumbnail <modgui/thumbnail-infinity.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Infinity" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "wood1" ;
        modgui:knob "purple" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "filter" ;
            lv2:name "Filter" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "damping" ;
            lv2:name "Damping" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "size" ;
            lv2:name "Size" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
