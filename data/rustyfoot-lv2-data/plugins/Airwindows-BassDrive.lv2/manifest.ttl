@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/bassdrive>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-bassdrive.html> ;
        modgui:stylesheet <modgui/stylesheet-bassdrive.css> ;
        modgui:screenshot <modgui/screenshot-bassdrive.png> ;
        modgui:thumbnail <modgui/thumbnail-bassdrive.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "BassDrive" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "wood4" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "presence" ;
            lv2:name "Presence" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "high" ;
            lv2:name "High" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "mid" ;
            lv2:name "Mid" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "low" ;
            lv2:name "Low" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] ;
    ] .
