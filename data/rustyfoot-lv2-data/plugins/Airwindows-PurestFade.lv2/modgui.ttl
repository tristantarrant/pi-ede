@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/purestfade>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-purestfade.html> ;
        modgui:stylesheet <modgui/stylesheet-purestfade.css> ;
        modgui:screenshot <modgui/screenshot-purestfade.png> ;
        modgui:thumbnail <modgui/thumbnail-purestfade.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "PurestFade" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "petrol" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "gain" ;
            lv2:name "Gain" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "fade" ;
            lv2:name "Fade" ;
        ] ;
    ] .
