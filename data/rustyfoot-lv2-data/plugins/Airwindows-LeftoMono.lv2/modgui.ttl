@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/leftomono>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-leftomono.html> ;
        modgui:stylesheet <modgui/stylesheet-leftomono.css> ;
        modgui:screenshot <modgui/screenshot-leftomono.png> ;
        modgui:thumbnail <modgui/thumbnail-leftomono.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "LeftoMono" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "pink" ;
    ] .
