@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/purestgain>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-purestgain.html> ;
        modgui:stylesheet <modgui/stylesheet-purestgain.css> ;
        modgui:screenshot <modgui/screenshot-purestgain.png> ;
        modgui:thumbnail <modgui/thumbnail-purestgain.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "PurestGain" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "gold" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "gain" ;
            lv2:name "Gain" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "slowfade" ;
            lv2:name "Slow Fade" ;
        ] ;
    ] .
