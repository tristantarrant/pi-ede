@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<http://sfztools.github.io/sfizz>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-sfizz.html> ;
        modgui:stylesheet <modgui/stylesheet-sfizz.css> ;
        modgui:screenshot <modgui/screenshot-sfizz.png> ;
        modgui:thumbnail <modgui/thumbnail-sfizz.png> ;
        modgui:brand "SFZTools" ;
        modgui:label "sfizz" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "zinc" ;
        modgui:knob "aluminium" ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "volume" ;
            lv2:name "Volume" ;
        ] ;
    ] .