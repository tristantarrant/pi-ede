@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/purestconsolechannel>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-purestconsolechannel.html> ;
        modgui:stylesheet <modgui/stylesheet-purestconsolechannel.css> ;
        modgui:screenshot <modgui/screenshot-purestconsolechannel.png> ;
        modgui:thumbnail <modgui/thumbnail-purestconsolechannel.png> ;
        modgui:brand "Hannes" ;
        modgui:label "PurestConsoleChannel" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "lava" ;
    ] .
