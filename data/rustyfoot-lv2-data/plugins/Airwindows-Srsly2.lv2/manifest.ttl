@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/srsly2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-srsly2.html> ;
        modgui:stylesheet <modgui/stylesheet-srsly2.css> ;
        modgui:screenshot <modgui/screenshot-srsly2.png> ;
        modgui:thumbnail <modgui/thumbnail-srsly2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Srsly2" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "petrol" ;
        modgui:knob "petrol" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "center" ;
            lv2:name "Center" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "space" ;
            lv2:name "Space" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "level" ;
            lv2:name "Level" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "q" ;
            lv2:name "Q" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
