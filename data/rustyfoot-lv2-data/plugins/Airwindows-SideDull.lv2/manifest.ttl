@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/sidedull>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-sidedull.html> ;
        modgui:stylesheet <modgui/stylesheet-sidedull.css> ;
        modgui:screenshot <modgui/screenshot-sidedull.png> ;
        modgui:thumbnail <modgui/thumbnail-sidedull.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "SideDull" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "tribal1" ;
        modgui:knob "blue" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "cutoff" ;
            lv2:name "Cutoff" ;
        ] ;
    ] .
