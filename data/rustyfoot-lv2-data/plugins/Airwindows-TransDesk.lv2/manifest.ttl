@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/transdesk>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-transdesk.html> ;
        modgui:stylesheet <modgui/stylesheet-transdesk.css> ;
        modgui:screenshot <modgui/screenshot-transdesk.png> ;
        modgui:thumbnail <modgui/thumbnail-transdesk.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "TransDesk" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "gray" ;
    ] .
