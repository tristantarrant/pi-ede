@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/monitoring>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-monitoring.html> ;
        modgui:stylesheet <modgui/stylesheet-monitoring.css> ;
        modgui:screenshot <modgui/screenshot-monitoring.png> ;
        modgui:thumbnail <modgui/thumbnail-monitoring.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Monitoring" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "darkblue" ;
        modgui:knob "aluminium" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "monitor" ;
            lv2:name "Monitor" ;
        ] ;
    ] .
