@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/totape6>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-totape6.html> ;
        modgui:stylesheet <modgui/stylesheet-totape6.css> ;
        modgui:screenshot <modgui/screenshot-totape6.png> ;
        modgui:thumbnail <modgui/thumbnail-totape6.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ToTape6" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "gold" ;
        modgui:knob "purple" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "input" ;
            lv2:name "Input" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "soften" ;
            lv2:name "Soften" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "headbump" ;
            lv2:name "Head Bump" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "flutter" ;
            lv2:name "Flutter" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
