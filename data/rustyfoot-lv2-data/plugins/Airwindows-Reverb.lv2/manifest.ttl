@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/reverb>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-reverb.html> ;
        modgui:stylesheet <modgui/stylesheet-reverb.css> ;
        modgui:screenshot <modgui/screenshot-reverb.png> ;
        modgui:thumbnail <modgui/thumbnail-reverb.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Reverb" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "dots" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "big" ;
            lv2:name "Big" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "wet" ;
            lv2:name "Wet" ;
        ] ;
    ] .
