@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/verbity>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-verbity.html> ;
        modgui:stylesheet <modgui/stylesheet-verbity.css> ;
        modgui:screenshot <modgui/screenshot-verbity.png> ;
        modgui:thumbnail <modgui/thumbnail-verbity.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Verbity" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "purple" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "bigness" ;
            lv2:name "Bigness" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "longness" ;
            lv2:name "Longness" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "darkness" ;
            lv2:name "Darkness" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "wetness" ;
            lv2:name "Wetness" ;
        ] ;
    ] .
