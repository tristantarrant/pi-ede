@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/glitchshifter>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-glitchshifter.html> ;
        modgui:stylesheet <modgui/stylesheet-glitchshifter.css> ;
        modgui:screenshot <modgui/screenshot-glitchshifter.png> ;
        modgui:thumbnail <modgui/thumbnail-glitchshifter.png> ;
        modgui:brand "Hannes" ;
        modgui:label "GlitchShifter" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "pink" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "note" ;
            lv2:name "Note" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "trim" ;
            lv2:name "Trim" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "tighten" ;
            lv2:name "Tighten" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "feedback" ;
            lv2:name "Feedback" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
