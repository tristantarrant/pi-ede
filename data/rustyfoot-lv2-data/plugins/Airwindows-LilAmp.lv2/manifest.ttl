@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/lilamp>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-lilamp.html> ;
        modgui:stylesheet <modgui/stylesheet-lilamp.css> ;
        modgui:screenshot <modgui/screenshot-lilamp.png> ;
        modgui:thumbnail <modgui/thumbnail-lilamp.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "LilAmp" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "slime" ;
        modgui:knob "purple" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "gain" ;
            lv2:name "Gain" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "tone" ;
            lv2:name "Tone" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
