@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/spiral2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-spiral2.html> ;
        modgui:stylesheet <modgui/stylesheet-spiral2.css> ;
        modgui:screenshot <modgui/screenshot-spiral2.png> ;
        modgui:thumbnail <modgui/thumbnail-spiral2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Spiral2" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "racing" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "input" ;
            lv2:name "Input" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "highpass" ;
            lv2:name "Highpass" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "presence" ;
            lv2:name "Presence" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
