@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/hull2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-hull2.html> ;
        modgui:stylesheet <modgui/stylesheet-hull2.css> ;
        modgui:screenshot <modgui/screenshot-hull2.png> ;
        modgui:thumbnail <modgui/thumbnail-hull2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Hull2" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "brown" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "treble" ;
            lv2:name "Treble" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "mid" ;
            lv2:name "Mid" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "bass" ;
            lv2:name "Bass" ;
        ] ;
    ] .
