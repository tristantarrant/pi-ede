@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/reseq2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-reseq2.html> ;
        modgui:stylesheet <modgui/stylesheet-reseq2.css> ;
        modgui:screenshot <modgui/screenshot-reseq2.png> ;
        modgui:thumbnail <modgui/thumbnail-reseq2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ResEQ2" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "wood0" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "mSweep" ;
            lv2:name "MSweep" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "mBoost" ;
            lv2:name "MBoost" ;
        ] ;
    ] .
