@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/brightambience3>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-brightambience3.html> ;
        modgui:stylesheet <modgui/stylesheet-brightambience3.css> ;
        modgui:screenshot <modgui/screenshot-brightambience3.png> ;
        modgui:thumbnail <modgui/thumbnail-brightambience3.png> ;
        modgui:brand "Hannes" ;
        modgui:label "BrightAmbience3" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "white" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "start" ;
            lv2:name "Start" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "length" ;
            lv2:name "Length" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "feedback" ;
            lv2:name "Feedback" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
