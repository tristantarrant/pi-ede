@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/finalclip>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-finalclip.html> ;
        modgui:stylesheet <modgui/stylesheet-finalclip.css> ;
        modgui:screenshot <modgui/screenshot-finalclip.png> ;
        modgui:thumbnail <modgui/thumbnail-finalclip.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "FinalClip" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "white" ;
    ] .
