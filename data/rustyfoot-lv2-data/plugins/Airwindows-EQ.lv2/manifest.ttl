@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/eq>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-eq.html> ;
        modgui:stylesheet <modgui/stylesheet-eq.css> ;
        modgui:screenshot <modgui/screenshot-eq.png> ;
        modgui:thumbnail <modgui/thumbnail-eq.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "EQ" ;
        modgui:model "boxy" ;
        modgui:panel "8-knobs" ;
        modgui:color "zinc" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "treble" ;
            lv2:name "Treble" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "mid" ;
            lv2:name "Mid" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "bass" ;
            lv2:name "Bass" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "lowpass" ;
            lv2:name "Lowpass" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "trebFrq" ;
            lv2:name "TrebFrq" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "bassFrq" ;
            lv2:name "BassFrq" ;
        ] , [
            lv2:index 10 ;
            lv2:symbol "hipass" ;
            lv2:name "Hipass" ;
        ] , [
            lv2:index 11 ;
            lv2:symbol "outGain" ;
            lv2:name "OutGain" ;
        ] ;
    ] .
