@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/pointyguitar>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-pointyguitar.html> ;
        modgui:stylesheet <modgui/stylesheet-pointyguitar.css> ;
        modgui:screenshot <modgui/screenshot-pointyguitar.png> ;
        modgui:thumbnail <modgui/thumbnail-pointyguitar.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "PointyGuitar" ;
        modgui:model "boxy" ;
        modgui:panel "8-knobs" ;
        modgui:color "wood0" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "presnce" ;
            lv2:name "Presnce" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "high" ;
            lv2:name "High" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "mid" ;
            lv2:name "Mid" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "low" ;
            lv2:name "Low" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "sub" ;
            lv2:name "Sub" ;
        ] , [
            lv2:index 10 ;
            lv2:symbol "hSpeakr" ;
            lv2:name "HSpeakr" ;
        ] , [
            lv2:index 11 ;
            lv2:symbol "lSpeakr" ;
            lv2:name "LSpeakr" ;
        ] , [
            lv2:index 12 ;
            lv2:symbol "gate" ;
            lv2:name "Gate" ;
        ] , [
            lv2:index 13 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] ;
    ] .
