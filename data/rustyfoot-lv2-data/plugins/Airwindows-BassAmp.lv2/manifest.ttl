@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/bassamp>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-bassamp.html> ;
        modgui:stylesheet <modgui/stylesheet-bassamp.css> ;
        modgui:screenshot <modgui/screenshot-bassamp.png> ;
        modgui:thumbnail <modgui/thumbnail-bassamp.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "BassAmp" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "blue" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "high" ;
            lv2:name "High" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "dry" ;
            lv2:name "Dry" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "dub" ;
            lv2:name "Dub" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "sub" ;
            lv2:name "Sub" ;
        ] ;
    ] .
