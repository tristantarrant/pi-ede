@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/console6channel>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-console6channel.html> ;
        modgui:stylesheet <modgui/stylesheet-console6channel.css> ;
        modgui:screenshot <modgui/screenshot-console6channel.png> ;
        modgui:thumbnail <modgui/thumbnail-console6channel.png> ;
        modgui:brand "Hannes" ;
        modgui:label "Console6Channel" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "petrol" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "input" ;
            lv2:name "Input" ;
        ] ;
    ] .
