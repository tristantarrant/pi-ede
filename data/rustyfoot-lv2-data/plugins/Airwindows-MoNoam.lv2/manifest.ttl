@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/monoam>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-monoam.html> ;
        modgui:stylesheet <modgui/stylesheet-monoam.css> ;
        modgui:screenshot <modgui/screenshot-monoam.png> ;
        modgui:thumbnail <modgui/thumbnail-monoam.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "MoNoam" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "tribal1" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "monotor" ;
            lv2:name "Monotor" ;
        ] ;
    ] .
