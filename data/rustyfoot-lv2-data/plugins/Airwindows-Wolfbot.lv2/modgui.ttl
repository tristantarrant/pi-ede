@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/wolfbot>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-wolfbot.html> ;
        modgui:stylesheet <modgui/stylesheet-wolfbot.css> ;
        modgui:screenshot <modgui/screenshot-wolfbot.png> ;
        modgui:thumbnail <modgui/thumbnail-wolfbot.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Wolfbot" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "wood2" ;
    ] .
