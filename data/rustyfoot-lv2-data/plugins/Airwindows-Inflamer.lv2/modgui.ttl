@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/inflamer>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-inflamer.html> ;
        modgui:stylesheet <modgui/stylesheet-inflamer.css> ;
        modgui:screenshot <modgui/screenshot-inflamer.png> ;
        modgui:thumbnail <modgui/thumbnail-inflamer.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Inflamer" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "red" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "curve" ;
            lv2:name "Curve" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "effect" ;
            lv2:name "Effect" ;
        ] ;
    ] .
