@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/air3>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-air3.html> ;
        modgui:stylesheet <modgui/stylesheet-air3.css> ;
        modgui:screenshot <modgui/screenshot-air3.png> ;
        modgui:thumbnail <modgui/thumbnail-air3.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Air3" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "lava" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "air" ;
            lv2:name "Air" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "gnd" ;
            lv2:name "Gnd" ;
        ] ;
    ] .
