@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/reseq>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-reseq.html> ;
        modgui:stylesheet <modgui/stylesheet-reseq.css> ;
        modgui:screenshot <modgui/screenshot-reseq.png> ;
        modgui:thumbnail <modgui/thumbnail-reseq.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ResEQ" ;
        modgui:model "boxy" ;
        modgui:panel "8-knobs" ;
        modgui:color "zinc" ;
        modgui:knob "copper" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "reso1" ;
            lv2:name "Reso 1" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "reso2" ;
            lv2:name "Reso 2" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "reso3" ;
            lv2:name "Reso 3" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "reso4" ;
            lv2:name "Reso 4" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "reso5" ;
            lv2:name "Reso 5" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "reso6" ;
            lv2:name "Reso 6" ;
        ] , [
            lv2:index 10 ;
            lv2:symbol "reso7" ;
            lv2:name "Reso 7" ;
        ] , [
            lv2:index 11 ;
            lv2:symbol "reso8" ;
            lv2:name "Reso 8" ;
        ] , [
            lv2:index 12 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
