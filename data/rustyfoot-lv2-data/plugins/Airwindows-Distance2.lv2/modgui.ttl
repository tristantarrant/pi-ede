@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/distance2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-distance2.html> ;
        modgui:stylesheet <modgui/stylesheet-distance2.css> ;
        modgui:screenshot <modgui/screenshot-distance2.png> ;
        modgui:thumbnail <modgui/thumbnail-distance2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Distance2" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "black" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "atmosphere" ;
            lv2:name "Atmosphere" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "darken" ;
            lv2:name "Darken" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
