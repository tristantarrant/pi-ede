@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/adt>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-adt.html> ;
        modgui:stylesheet <modgui/stylesheet-adt.css> ;
        modgui:screenshot <modgui/screenshot-adt.png> ;
        modgui:thumbnail <modgui/thumbnail-adt.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ADT" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "dots" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "headroom" ;
            lv2:name "Headroom" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "aDelay" ;
            lv2:name "A Delay" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "aLevel" ;
            lv2:name "A Level" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "bDelay" ;
            lv2:name "B Delay" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "bLevel" ;
            lv2:name "B Level" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] ;
    ] .
