@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/xregion>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-xregion.html> ;
        modgui:stylesheet <modgui/stylesheet-xregion.css> ;
        modgui:screenshot <modgui/screenshot-xregion.png> ;
        modgui:thumbnail <modgui/thumbnail-xregion.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "XRegion" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "yellow" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "gain" ;
            lv2:name "Gain" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "first" ;
            lv2:name "First" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "last" ;
            lv2:name "Last" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "nuke" ;
            lv2:name "Nuke" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
