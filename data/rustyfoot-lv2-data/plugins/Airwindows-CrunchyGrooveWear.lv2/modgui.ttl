@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/crunchygroovewear>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-crunchygroovewear.html> ;
        modgui:stylesheet <modgui/stylesheet-crunchygroovewear.css> ;
        modgui:screenshot <modgui/screenshot-crunchygroovewear.png> ;
        modgui:thumbnail <modgui/thumbnail-crunchygroovewear.png> ;
        modgui:brand "Hannes" ;
        modgui:label "CrunchyGrooveWear" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "green" ;
        modgui:knob "blue" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "freq" ;
            lv2:name "Freq" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "apply" ;
            lv2:name "Apply" ;
        ] ;
    ] .
