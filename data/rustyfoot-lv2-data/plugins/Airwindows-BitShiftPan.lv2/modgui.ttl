@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/bitshiftpan>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-bitshiftpan.html> ;
        modgui:stylesheet <modgui/stylesheet-bitshiftpan.css> ;
        modgui:screenshot <modgui/screenshot-bitshiftpan.png> ;
        modgui:thumbnail <modgui/thumbnail-bitshiftpan.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "BitShiftPan" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "gray" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "vol" ;
            lv2:name "Vol" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "pan" ;
            lv2:name "Pan" ;
        ] ;
    ] .
