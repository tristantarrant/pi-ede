@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/focus>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-focus.html> ;
        modgui:stylesheet <modgui/stylesheet-focus.css> ;
        modgui:screenshot <modgui/screenshot-focus.png> ;
        modgui:thumbnail <modgui/thumbnail-focus.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Focus" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "yellow" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "boost" ;
            lv2:name "Boost" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "focus" ;
            lv2:name "Focus" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "mode" ;
            lv2:name "Mode" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
