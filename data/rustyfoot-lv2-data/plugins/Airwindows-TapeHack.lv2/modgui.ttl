@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/tapehack>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-tapehack.html> ;
        modgui:stylesheet <modgui/stylesheet-tapehack.css> ;
        modgui:screenshot <modgui/screenshot-tapehack.png> ;
        modgui:thumbnail <modgui/thumbnail-tapehack.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "TapeHack" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "white" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "input" ;
            lv2:name "Input" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
