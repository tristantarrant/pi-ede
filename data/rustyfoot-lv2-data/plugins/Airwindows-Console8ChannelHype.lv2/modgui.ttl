@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/console8channelhype>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-console8channelhype.html> ;
        modgui:stylesheet <modgui/stylesheet-console8channelhype.css> ;
        modgui:screenshot <modgui/screenshot-console8channelhype.png> ;
        modgui:thumbnail <modgui/thumbnail-console8channelhype.png> ;
        modgui:brand "Hannes" ;
        modgui:label "Console8ChannelHype" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "gray" ;
    ] .
