@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/kcosmos>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-kcosmos.html> ;
        modgui:stylesheet <modgui/stylesheet-kcosmos.css> ;
        modgui:screenshot <modgui/screenshot-kcosmos.png> ;
        modgui:thumbnail <modgui/thumbnail-kcosmos.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "kCosmos" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "regen" ;
            lv2:name "Regen" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "derez" ;
            lv2:name "Derez" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "filter" ;
            lv2:name "Filter" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "earlyRF" ;
            lv2:name "EarlyRF" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "predlay" ;
            lv2:name "Predlay" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
