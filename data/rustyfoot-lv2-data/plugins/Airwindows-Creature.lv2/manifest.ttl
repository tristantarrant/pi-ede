@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/creature>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-creature.html> ;
        modgui:stylesheet <modgui/stylesheet-creature.css> ;
        modgui:screenshot <modgui/screenshot-creature.png> ;
        modgui:thumbnail <modgui/thumbnail-creature.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Creature" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "purple" ;
        modgui:knob "petrol" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "depth" ;
            lv2:name "Depth" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "invWet" ;
            lv2:name "Inv/Wet" ;
        ] ;
    ] .
