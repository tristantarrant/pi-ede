@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/everyslew>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-everyslew.html> ;
        modgui:stylesheet <modgui/stylesheet-everyslew.css> ;
        modgui:screenshot <modgui/screenshot-everyslew.png> ;
        modgui:thumbnail <modgui/thumbnail-everyslew.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "EverySlew" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "wood1" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "slew" ;
            lv2:name "Slew" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "depth" ;
            lv2:name "Depth" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "halo" ;
            lv2:name "Halo" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "invWet" ;
            lv2:name "Inv/Wet" ;
        ] ;
    ] .
