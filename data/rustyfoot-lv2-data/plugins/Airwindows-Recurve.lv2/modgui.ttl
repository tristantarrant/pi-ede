@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/recurve>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-recurve.html> ;
        modgui:stylesheet <modgui/stylesheet-recurve.css> ;
        modgui:screenshot <modgui/screenshot-recurve.png> ;
        modgui:thumbnail <modgui/thumbnail-recurve.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Recurve" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "dots" ;
    ] .
