@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/mastering>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-mastering.html> ;
        modgui:stylesheet <modgui/stylesheet-mastering.css> ;
        modgui:screenshot <modgui/screenshot-mastering.png> ;
        modgui:thumbnail <modgui/thumbnail-mastering.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Mastering" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "flowerpower" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "glue" ;
            lv2:name "Glue" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "scope" ;
            lv2:name "Scope" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "skronk" ;
            lv2:name "Skronk" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "girth" ;
            lv2:name "Girth" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "dither" ;
            lv2:name "Dither" ;
        ] ;
    ] .
