@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/drive>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-drive.html> ;
        modgui:stylesheet <modgui/stylesheet-drive.css> ;
        modgui:screenshot <modgui/screenshot-drive.png> ;
        modgui:thumbnail <modgui/thumbnail-drive.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Drive" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "highpass" ;
            lv2:name "Highpass" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "outLevel" ;
            lv2:name "Out Level" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
