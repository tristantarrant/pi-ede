@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/totape5>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-totape5.html> ;
        modgui:stylesheet <modgui/stylesheet-totape5.css> ;
        modgui:screenshot <modgui/screenshot-totape5.png> ;
        modgui:thumbnail <modgui/thumbnail-totape5.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ToTape5" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "gray" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "louder" ;
            lv2:name "Louder" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "softer" ;
            lv2:name "Softer" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "fatter" ;
            lv2:name "Fatter" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "flutter" ;
            lv2:name "Flutter" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
