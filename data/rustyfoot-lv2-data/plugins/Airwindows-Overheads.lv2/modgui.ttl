@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/overheads>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-overheads.html> ;
        modgui:stylesheet <modgui/stylesheet-overheads.css> ;
        modgui:screenshot <modgui/screenshot-overheads.png> ;
        modgui:thumbnail <modgui/thumbnail-overheads.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Overheads" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "orange" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "compr" ;
            lv2:name "Compr" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "sharp" ;
            lv2:name "Sharp" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
