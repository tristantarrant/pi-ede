@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/desk>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-desk.html> ;
        modgui:stylesheet <modgui/stylesheet-desk.css> ;
        modgui:screenshot <modgui/screenshot-desk.png> ;
        modgui:thumbnail <modgui/thumbnail-desk.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Desk" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "orange" ;
    ] .
