@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/flipity>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-flipity.html> ;
        modgui:stylesheet <modgui/stylesheet-flipity.css> ;
        modgui:screenshot <modgui/screenshot-flipity.png> ;
        modgui:thumbnail <modgui/thumbnail-flipity.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Flipity" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "slime" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "flipity" ;
            lv2:name "Flipity" ;
        ] ;
    ] .
