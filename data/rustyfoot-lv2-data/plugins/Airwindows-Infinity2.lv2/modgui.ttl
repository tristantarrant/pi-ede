@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/infinity2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-infinity2.html> ;
        modgui:stylesheet <modgui/stylesheet-infinity2.css> ;
        modgui:screenshot <modgui/screenshot-infinity2.png> ;
        modgui:thumbnail <modgui/thumbnail-infinity2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Infinity2" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "flowerpower" ;
        modgui:knob "purple" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "filter" ;
            lv2:name "Filter" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "size" ;
            lv2:name "Size" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "damping" ;
            lv2:name "Damping" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "allpass" ;
            lv2:name "Allpass" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "feedback" ;
            lv2:name "Feedback" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
