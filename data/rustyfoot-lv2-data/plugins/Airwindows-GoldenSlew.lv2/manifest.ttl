@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/goldenslew>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-goldenslew.html> ;
        modgui:stylesheet <modgui/stylesheet-goldenslew.css> ;
        modgui:screenshot <modgui/screenshot-goldenslew.png> ;
        modgui:thumbnail <modgui/thumbnail-goldenslew.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "GoldenSlew" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "tribal2" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "slew" ;
            lv2:name "Slew" ;
        ] ;
    ] .
