@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/sinew>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-sinew.html> ;
        modgui:stylesheet <modgui/stylesheet-sinew.css> ;
        modgui:screenshot <modgui/screenshot-sinew.png> ;
        modgui:thumbnail <modgui/thumbnail-sinew.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Sinew" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "tribal1" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "sinew" ;
            lv2:name "Sinew" ;
        ] ;
    ] .
