@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/hypersonic>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-hypersonic.html> ;
        modgui:stylesheet <modgui/stylesheet-hypersonic.css> ;
        modgui:screenshot <modgui/screenshot-hypersonic.png> ;
        modgui:thumbnail <modgui/thumbnail-hypersonic.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Hypersonic" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "tribal1" ;
    ] .
