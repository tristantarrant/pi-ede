@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/powersag2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-powersag2.html> ;
        modgui:stylesheet <modgui/stylesheet-powersag2.css> ;
        modgui:screenshot <modgui/screenshot-powersag2.png> ;
        modgui:thumbnail <modgui/thumbnail-powersag2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "PowerSag2" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "lava" ;
        modgui:knob "purple" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "range" ;
            lv2:name "Range" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "invWet" ;
            lv2:name "Inv/Wet" ;
        ] ;
    ] .
