@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/pitchnasty>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-pitchnasty.html> ;
        modgui:stylesheet <modgui/stylesheet-pitchnasty.css> ;
        modgui:screenshot <modgui/screenshot-pitchnasty.png> ;
        modgui:thumbnail <modgui/thumbnail-pitchnasty.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "PitchNasty" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "pink" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "note" ;
            lv2:name "Note" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "bend" ;
            lv2:name "Bend" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "grind" ;
            lv2:name "Grind" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "feedback" ;
            lv2:name "Feedback" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 9 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
