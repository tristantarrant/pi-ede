@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/tpdfdither>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-tpdfdither.html> ;
        modgui:stylesheet <modgui/stylesheet-tpdfdither.css> ;
        modgui:screenshot <modgui/screenshot-tpdfdither.png> ;
        modgui:thumbnail <modgui/thumbnail-tpdfdither.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "TPDFDither" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "petrol" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "quantizer" ;
            lv2:name "Quantizer" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "deRez" ;
            lv2:name "DeRez" ;
        ] ;
    ] .
