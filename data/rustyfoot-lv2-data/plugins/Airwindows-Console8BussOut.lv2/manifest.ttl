@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/console8bussout>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-console8bussout.html> ;
        modgui:stylesheet <modgui/stylesheet-console8bussout.css> ;
        modgui:screenshot <modgui/screenshot-console8bussout.png> ;
        modgui:thumbnail <modgui/thumbnail-console8bussout.png> ;
        modgui:brand "Hannes" ;
        modgui:label "Console8BussOut" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "wood3" ;
        modgui:knob "purple" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "fader" ;
            lv2:name "Fader" ;
        ] ;
    ] .
