@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/pop>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-pop.html> ;
        modgui:stylesheet <modgui/stylesheet-pop.css> ;
        modgui:screenshot <modgui/screenshot-pop.png> ;
        modgui:thumbnail <modgui/thumbnail-pop.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Pop" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "slime" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "intensity" ;
            lv2:name "Intensity" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
