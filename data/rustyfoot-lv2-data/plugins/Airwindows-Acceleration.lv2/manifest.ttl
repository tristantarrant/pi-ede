@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/acceleration>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-acceleration.html> ;
        modgui:stylesheet <modgui/stylesheet-acceleration.css> ;
        modgui:screenshot <modgui/screenshot-acceleration.png> ;
        modgui:thumbnail <modgui/thumbnail-acceleration.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Acceleration" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "purple" ;
        modgui:knob "steel" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "limit" ;
            lv2:name "Limit" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
