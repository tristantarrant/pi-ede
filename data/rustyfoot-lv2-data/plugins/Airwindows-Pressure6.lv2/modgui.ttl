@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/pressure6>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-pressure6.html> ;
        modgui:stylesheet <modgui/stylesheet-pressure6.css> ;
        modgui:screenshot <modgui/screenshot-pressure6.png> ;
        modgui:thumbnail <modgui/thumbnail-pressure6.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Pressure6" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "gold" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "compres" ;
            lv2:name "Compres" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "ratio" ;
            lv2:name "Ratio" ;
        ] ;
    ] .
