@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/dirt>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-dirt.html> ;
        modgui:stylesheet <modgui/stylesheet-dirt.css> ;
        modgui:screenshot <modgui/screenshot-dirt.png> ;
        modgui:thumbnail <modgui/thumbnail-dirt.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Dirt" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "petrol" ;
        modgui:knob "copper" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "gain" ;
            lv2:name "Gain" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "lowpass" ;
            lv2:name "Lowpass" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "highpass" ;
            lv2:name "Highpass" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
