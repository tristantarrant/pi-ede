@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/purestwarm2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-purestwarm2.html> ;
        modgui:stylesheet <modgui/stylesheet-purestwarm2.css> ;
        modgui:screenshot <modgui/screenshot-purestwarm2.png> ;
        modgui:thumbnail <modgui/thumbnail-purestwarm2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "PurestWarm2" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "warning" ;
        modgui:knob "copper" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "dryPos" ;
            lv2:name "Dry/Pos" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "dryNeg" ;
            lv2:name "Dry/Neg" ;
        ] ;
    ] .
