@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/basskit>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-basskit.html> ;
        modgui:stylesheet <modgui/stylesheet-basskit.css> ;
        modgui:screenshot <modgui/screenshot-basskit.png> ;
        modgui:thumbnail <modgui/thumbnail-basskit.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "BassKit" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "warning" ;
        modgui:knob "blue" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "voicing" ;
            lv2:name "Voicing" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "bassOut" ;
            lv2:name "BassOut" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "subOut" ;
            lv2:name "SubOut" ;
        ] ;
    ] .
