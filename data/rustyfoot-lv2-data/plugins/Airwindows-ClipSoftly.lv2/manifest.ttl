@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/clipsoftly>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-clipsoftly.html> ;
        modgui:stylesheet <modgui/stylesheet-clipsoftly.css> ;
        modgui:screenshot <modgui/screenshot-clipsoftly.png> ;
        modgui:thumbnail <modgui/thumbnail-clipsoftly.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "ClipSoftly" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "wood2" ;
    ] .
