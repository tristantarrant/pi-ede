@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/drumslam>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-drumslam.html> ;
        modgui:stylesheet <modgui/stylesheet-drumslam.css> ;
        modgui:screenshot <modgui/screenshot-drumslam.png> ;
        modgui:thumbnail <modgui/thumbnail-drumslam.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "DrumSlam" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "zinc" ;
        modgui:knob "blue" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "output" ;
            lv2:name "Output" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "drywet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
