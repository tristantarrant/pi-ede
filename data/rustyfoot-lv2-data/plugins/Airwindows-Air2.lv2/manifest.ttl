@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/air2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-air2.html> ;
        modgui:stylesheet <modgui/stylesheet-air2.css> ;
        modgui:screenshot <modgui/screenshot-air2.png> ;
        modgui:thumbnail <modgui/thumbnail-air2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Air2" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "red" ;
        modgui:knob "silver" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "hiss" ;
            lv2:name "Hiss" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "glitter" ;
            lv2:name "Glitter" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "air" ;
            lv2:name "Air" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "silk" ;
            lv2:name "Silk" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
