@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/rawglitters>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-rawglitters.html> ;
        modgui:stylesheet <modgui/stylesheet-rawglitters.css> ;
        modgui:screenshot <modgui/screenshot-rawglitters.png> ;
        modgui:thumbnail <modgui/thumbnail-rawglitters.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "RawGlitters" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "blue" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "quantizer" ;
            lv2:name "Quantizer" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "deRez" ;
            lv2:name "DeRez" ;
        ] ;
    ] .
