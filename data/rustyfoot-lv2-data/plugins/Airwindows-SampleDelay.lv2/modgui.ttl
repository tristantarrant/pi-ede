@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/sampledelay>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-sampledelay.html> ;
        modgui:stylesheet <modgui/stylesheet-sampledelay.css> ;
        modgui:screenshot <modgui/screenshot-sampledelay.png> ;
        modgui:thumbnail <modgui/thumbnail-sampledelay.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "SampleDelay" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "black" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "ms" ;
            lv2:name "ms" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "samples" ;
            lv2:name "Samples" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "subsample" ;
            lv2:name "Subsample" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "invWet" ;
            lv2:name "Inv/Wet" ;
        ] ;
    ] .
