@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/highglossdither>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-highglossdither.html> ;
        modgui:stylesheet <modgui/stylesheet-highglossdither.css> ;
        modgui:screenshot <modgui/screenshot-highglossdither.png> ;
        modgui:thumbnail <modgui/thumbnail-highglossdither.png> ;
        modgui:brand "Hannes" ;
        modgui:label "HighGlossDither" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "cream" ;
    ] .
