@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/tube2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-tube2.html> ;
        modgui:stylesheet <modgui/stylesheet-tube2.css> ;
        modgui:screenshot <modgui/screenshot-tube2.png> ;
        modgui:thumbnail <modgui/thumbnail-tube2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Tube2" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "brown" ;
        modgui:knob "bronze" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "input" ;
            lv2:name "Input" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "tube" ;
            lv2:name "Tube" ;
        ] ;
    ] .
