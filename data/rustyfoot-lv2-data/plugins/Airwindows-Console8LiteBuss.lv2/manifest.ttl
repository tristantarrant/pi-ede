@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/console8litebuss>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-console8litebuss.html> ;
        modgui:stylesheet <modgui/stylesheet-console8litebuss.css> ;
        modgui:screenshot <modgui/screenshot-console8litebuss.png> ;
        modgui:thumbnail <modgui/thumbnail-console8litebuss.png> ;
        modgui:brand "Hannes" ;
        modgui:label "Console8LiteBuss" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "warning" ;
        modgui:knob "petrol" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "fader" ;
            lv2:name "Fader" ;
        ] ;
    ] .
