@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/point>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-point.html> ;
        modgui:stylesheet <modgui/stylesheet-point.css> ;
        modgui:screenshot <modgui/screenshot-point.png> ;
        modgui:thumbnail <modgui/thumbnail-point.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Point" ;
        modgui:model "boxy" ;
        modgui:panel "3-knobs" ;
        modgui:color "zinc" ;
        modgui:knob "purple" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "inputTrim" ;
            lv2:name "Input Trim" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "point" ;
            lv2:name "Point" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "reactionSpeed" ;
            lv2:name "Reaction Speed" ;
        ] ;
    ] .
