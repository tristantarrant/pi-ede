@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/pop2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-pop2.html> ;
        modgui:stylesheet <modgui/stylesheet-pop2.css> ;
        modgui:screenshot <modgui/screenshot-pop2.png> ;
        modgui:thumbnail <modgui/thumbnail-pop2.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Pop2" ;
        modgui:model "boxy" ;
        modgui:panel "5-knobs" ;
        modgui:color "cyan" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "compress" ;
            lv2:name "Compress" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "attack" ;
            lv2:name "Attack" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "release" ;
            lv2:name "Release" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 8 ;
            lv2:symbol "dryWet" ;
            lv2:name "Dry/Wet" ;
        ] ;
    ] .
