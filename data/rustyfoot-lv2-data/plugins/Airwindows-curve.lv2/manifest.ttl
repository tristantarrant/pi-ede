@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/curve>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-curve.html> ;
        modgui:stylesheet <modgui/stylesheet-curve.css> ;
        modgui:screenshot <modgui/screenshot-curve.png> ;
        modgui:thumbnail <modgui/thumbnail-curve.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "curve" ;
        modgui:model "boxy-small" ;
        modgui:panel "1-footswitch" ;
        modgui:color "darkblue" ;
    ] .
