@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/tube>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-tube.html> ;
        modgui:stylesheet <modgui/stylesheet-tube.css> ;
        modgui:screenshot <modgui/screenshot-tube.png> ;
        modgui:thumbnail <modgui/thumbnail-tube.png> ;
        modgui:brand "Airwindows" ;
        modgui:label "Tube" ;
        modgui:model "boxy" ;
        modgui:panel "1-knob" ;
        modgui:color "pink" ;
        modgui:knob "green" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "tube" ;
            lv2:name "TUBE" ;
        ] ;
    ] .
