@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://hannesbraun.net/ns/lv2/airwindows/console0channel>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-console0channel.html> ;
        modgui:stylesheet <modgui/stylesheet-console0channel.css> ;
        modgui:screenshot <modgui/screenshot-console0channel.png> ;
        modgui:thumbnail <modgui/thumbnail-console0channel.png> ;
        modgui:brand "Hannes" ;
        modgui:label "Console0Channel" ;
        modgui:model "boxy" ;
        modgui:panel "2-knobs" ;
        modgui:color "warning" ;
        modgui:knob "gold" ;
        modgui:port [
            lv2:index 4 ;
            lv2:symbol "vol" ;
            lv2:name "Vol" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "pan" ;
            lv2:name "Pan" ;
        ] ;
    ] .
